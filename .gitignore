# Local Data Artifacts (generated by pipeline)
# Bronze: ignore raw data, keep contracts
data_pipeline/bronze/*.json
!data_pipeline/bronze/*.contract.json

# Silver: ignore parquet data, keep contracts and metadata
data_pipeline/silver/*.parquet
!data_pipeline/silver/*.contract.json
!data_pipeline/silver/features_metadata.json

# Gold: ignore parquet data, keep contracts and metadata
data_pipeline/gold/*.parquet
!data_pipeline/gold/*.contract.json
!data_pipeline/gold/*_metadata*.json
!data_pipeline/gold/pipeline_run_report.json

