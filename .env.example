# NZ Habitat Intelligence - Environment Variables
# Copy this file to .env and fill in the values.
# DO NOT commit .env to version control.

# ── Pipeline ────────────────────────────────────────────────────────────
# Force refresh bronze data on every run (true/false)
FORCE_REFRESH=false

# Data directories (relative to project root)
BRONZE_DIR=data_pipeline/bronze
SILVER_DIR=data_pipeline/silver
GOLD_DIR=data_pipeline/gold
DBT_DIR=dbt_nz

# ── Alerting ────────────────────────────────────────────────────────────
# Cooldown between duplicate alerts (seconds)
ALERT_COOLDOWN_SECONDS=300

# Maximum alerts per pipeline run
ALERT_MAX_PER_RUN=50

# Webhook URL for Slack/Discord/Teams notifications (optional)
ALERT_WEBHOOK_URL=

# ── Logging ─────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file directory
LOG_DIR=logs

# ── Dashboard ───────────────────────────────────────────────────────────
# Dashboard host and port
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8050

# Debug mode for dashboard (true/false)
DASHBOARD_DEBUG=false

# ── AWS (for Terraform deployment) ──────────────────────────────────────
AWS_REGION=ap-southeast-2
AWS_PROFILE=default

# ── Prefect ─────────────────────────────────────────────────────────────
# Prefect server URL
PREFECT_API_URL=http://127.0.0.1:4200/api

# Prefect deployment name
PREFECT_DEPLOYMENT_NAME=nz-habitat-daily-pipeline

# ── Data Quality ────────────────────────────────────────────────────────
# Minimum confidence score to consider data trusted (0-100)
MIN_CONFIDENCE_THRESHOLD=70

# Maximum age of data before flagging as stale (days)
MAX_DATA_AGE_DAYS=45

# ── Secrets Management ──────────────────────────────────────────────────
# Backend: 'aws' (AWS Secrets Manager), 'env' (environment variables), or 'auto' (default)
SECRETS_BACKEND=auto

# AWS Secrets Manager prefix (if using AWS backend)
AWS_SECRET_PREFIX=nz-habitat/

# ── Export Configuration ────────────────────────────────────────────────
# Default export format: 'png', 'svg', 'html', 'pdf'
EXPORT_DEFAULT_FORMAT=html

# Export directory (relative to project root)
EXPORT_DIR=exports
